import wikipedia

while True:
    query = input("Ask something: ")

    if query.lower() == "quit":
        print("Ok bye")
        break

    try:
        answer = wikipedia.summary(query, sentences=2)
        print("Answer:", answer)

    except wikipedia.exceptions.DisambiguationError as e:
        print("Too many results. Try something more specific.")

    except wikipedia.exceptions.PageError:
        print("Sorry, no page found.")
